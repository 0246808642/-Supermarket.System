<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Supermercado</title>
    <link rel="stylesheet" href="~/css/site.min.css" asp-append-version="true" />
</head>
<body class="bg-background text-on-surface font-sans antialiased min-h-screen flex flex-col">
    <header class="bg-surface-container-lowest border-b border-outline-variant/30 sticky top-0 z-50">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <!-- Esquerda e Centro (Logo e Menus) -->
                <div class="flex items-center gap-8">
                    <!-- Logo -->
                    <a class="text-primary font-bold text-xl flex items-center gap-2" asp-area="" asp-page="/Index">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                        Supermarket
                    </a>
                    <!-- Menu -->
                    <div class="hidden md:flex gap-6">
                        <a class="text-on-surface-variant hover:text-primary transition-colors font-semibold" asp-area="" asp-page="/Produtos">Produtos</a>
                        <a class="text-on-surface-variant hover:text-primary transition-colors font-semibold" asp-area="" asp-page="/Sobre">Sobre</a>
                    </div>
                </div>

                <!-- Direita (Busca e Entrar) -->
                <div class="flex items-center gap-4">
                    <!-- Formulário de Busca -->
                    <form asp-page="/Produtos" method="get" class="relative hidden sm:block">
                        <input type="text" name="Q" placeholder="Pesquisar..." class="bg-surface-container-low text-on-surface border border-outline-variant/50 rounded-full py-2 pl-4 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all w-48 focus:w-64" />
                        <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors p-1">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </button>
                    </form>
                    <!-- Ícone Busca Mobile -->
                    <button class="sm:hidden text-on-surface-variant hover:text-primary transition-colors p-2" onclick="document.getElementById('mobile-search').classList.toggle('hidden')">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </button>
                    
                    <!-- Botão Entrar -->
                    <button type="button" onclick="openLoginModal()" class="btn-primary flex items-center gap-2 cursor-pointer">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                        Entrar
                    </button>
                </div>
            </div>
            
            <!-- Mobile Search Bar (Hidden by default) -->
            <div id="mobile-search" class="hidden pb-4 sm:hidden">
                <form asp-page="/Produtos" method="get" class="relative w-full">
                    <input type="text" name="Q" placeholder="Pesquisar produtos..." class="w-full bg-surface-container-low text-on-surface border border-outline-variant/50 rounded-lg py-2 pl-4 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
                    <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors p-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </button>
                </form>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        @RenderBody()
    </main>

    <footer class="bg-surface-container-lowest border-t border-outline-variant/30 py-8 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-4 text-on-surface-variant text-sm">
            <div>
                &copy; 2026 - Supermarket
            </div>
            <div class="flex gap-4">
                <a asp-area="" asp-page="/Sobre" class="hover:text-primary transition-colors">Sobre</a>
                <a href="#" class="hover:text-primary transition-colors">Termos de Uso</a>
            </div>
        </div>
    </footer>

    <!-- Modal de Login/Registro -->
    <div id="login-modal" class="fixed inset-0 z-[100] hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <!-- Background backdrop -->
        <div class="fixed inset-0 bg-on-surface/50 backdrop-blur-sm transition-opacity" onclick="closeLoginModal()"></div>

        <div class="fixed inset-0 z-10 w-screen overflow-y-auto">
            <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
                <div class="relative transform overflow-hidden rounded-xl bg-surface-container-lowest text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-md border border-outline-variant/30">
                    <div class="px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
                        <div class="flex justify-between items-center mb-5">
                            <h3 class="text-xl font-bold leading-6 text-on-surface" id="modal-title">Acessar Conta</h3>
                            <button type="button" onclick="closeLoginModal()" class="text-outline hover:text-on-surface transition-colors">
                                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            </button>
                        </div>
                        
                        <form action="#" method="POST" class="flex flex-col gap-4">
                            <div>
                                <label for="email" class="block text-sm font-medium text-on-surface-variant mb-1">E-mail</label>
                                <input type="email" name="email" id="email" class="block w-full rounded-md border-0 py-2 text-on-surface shadow-sm ring-1 ring-inset ring-outline-variant focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6 px-3 bg-surface-container-low" placeholder="seu@email.com">
                            </div>
                            <div>
                                <label for="password" class="block text-sm font-medium text-on-surface-variant mb-1">Senha</label>
                                <input type="password" name="password" id="password" class="block w-full rounded-md border-0 py-2 text-on-surface shadow-sm ring-1 ring-inset ring-outline-variant focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6 px-3 bg-surface-container-low" placeholder="••••••••">
                            </div>
                            <div class="flex items-center justify-between mt-2">
                                <div class="flex items-center">
                                    <input id="remember-me" name="remember-me" type="checkbox" class="h-4 w-4 rounded border-outline-variant text-primary focus:ring-primary bg-surface-container-low">
                                    <label for="remember-me" class="ml-2 block text-sm text-on-surface-variant">Lembrar-me</label>
                                </div>
                                <div class="text-sm">
                                    <a href="#" class="font-semibold text-primary hover:text-primary-container transition-colors">Esqueceu a senha?</a>
                                </div>
                            </div>
                            <button type="button" class="btn-primary w-full mt-2 py-2 text-center justify-center">Entrar</button>
                        </form>

                        <div class="mt-6 text-center text-sm text-on-surface-variant">
                            Ainda não tem conta? <a href="#" class="font-semibold text-primary hover:text-primary-container transition-colors">Cadastre-se</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function openLoginModal() {
            document.getElementById('login-modal').classList.remove('hidden');
        }
        function closeLoginModal() {
            document.getElementById('login-modal').classList.add('hidden');
        }
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
