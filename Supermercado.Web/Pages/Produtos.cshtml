@page
@model ProdutosModel
@{
    ViewData["Title"] = "Todos os Produtos";
}

<div class="mb-8">
    <h1 class="text-3xl font-bold text-on-surface mb-2">
        @if (!string.IsNullOrEmpty(Model.Q))
        {
            <span>Resultados para "@Model.Q"</span>
        }
        else
        {
            <span>Todos os Produtos</span>
        }
    </h1>
    <p class="text-on-surface-variant">Confira todo o nosso catálogo de produtos.</p>
</div>

@if (Model.Products.Any())
{
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        @foreach (var product in Model.Products)
        {
            <div class="card flex flex-col h-full group hover:shadow-md transition-shadow">
                <div class="aspect-square bg-surface-container rounded-md mb-4 overflow-hidden relative flex items-center justify-center">
                    @if (string.IsNullOrEmpty(product.ImageUrl))
                    {
                        <svg class="w-12 h-12 text-outline/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    }
                    else
                    {
                        <img src="@product.ImageUrl" alt="@product.Name" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                    }
                    
                    @if (product.DiscountedPrice > 0 && product.DiscountedPrice < product.Price)
                    {
                        <span class="absolute top-2 left-2 bg-tertiary text-on-tertiary text-xs font-bold px-2 py-1 rounded-full">
                            Oferta
                        </span>
                    }
                </div>
                
                <div class="flex flex-col flex-grow">
                    <span class="text-xs text-outline font-semibold uppercase tracking-wider mb-1">Categoria</span>
                    <h3 class="text-lg font-semibold text-on-surface mb-1 line-clamp-2">@product.Name</h3>
                    
                    <div class="mt-auto pt-4 flex items-center justify-between">
                        <div>
                            @if (product.DiscountedPrice > 0 && product.DiscountedPrice < product.Price)
                            {
                                <div class="text-xs text-outline line-through">R$ @product.Price.ToString("N2")</div>
                                <div class="text-xl font-bold text-on-surface">R$ @product.DiscountedPrice.ToString("N2")</div>
                            }
                            else
                            {
                                <div class="text-xl font-bold text-on-surface">R$ @product.Price.ToString("N2")</div>
                            }
                        </div>
                        
                        <button class="bg-primary/10 hover:bg-primary text-primary hover:text-on-primary rounded-full p-2 transition-colors" title="Adicionar ao carrinho">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="flex justify-center mt-12">
            <nav class="inline-flex rounded-md shadow-sm" aria-label="Pagination">
                @if (Model.CurrentPage > 1)
                {
                    <a asp-page="/Produtos" asp-route-Q="@Model.Q" asp-route-CurrentPage="@(Model.CurrentPage - 1)" class="relative inline-flex items-center rounded-l-md px-2 py-2 text-outline ring-1 ring-inset ring-outline-variant hover:bg-surface-container-low focus:z-20 focus:outline-offset-0">
                        <span class="sr-only">Anterior</span>
                        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
                        </svg>
                    </a>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.CurrentPage)
                    {
                        <span class="relative z-10 inline-flex items-center bg-primary px-4 py-2 text-sm font-semibold text-on-primary focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">@i</span>
                    }
                    else
                    {
                        <a asp-page="/Produtos" asp-route-Q="@Model.Q" asp-route-CurrentPage="@i" class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-on-surface ring-1 ring-inset ring-outline-variant hover:bg-surface-container-low focus:z-20 focus:outline-offset-0">@i</a>
                    }
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a asp-page="/Produtos" asp-route-Q="@Model.Q" asp-route-CurrentPage="@(Model.CurrentPage + 1)" class="relative inline-flex items-center rounded-r-md px-2 py-2 text-outline ring-1 ring-inset ring-outline-variant hover:bg-surface-container-low focus:z-20 focus:outline-offset-0">
                        <span class="sr-only">Próxima</span>
                        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                        </svg>
                    </a>
                }
            </nav>
        </div>
    }
}
else
{
    <div class="bg-surface-container-low rounded-lg p-12 text-center border border-outline-variant/30">
        <svg class="mx-auto h-12 w-12 text-outline mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        <h3 class="text-lg font-medium text-on-surface mb-2">Nenhum produto encontrado</h3>
        <p class="text-on-surface-variant">Tente buscar por outro termo.</p>
    </div>
}
